# Django Configuration
SECRET_KEY=django-insecure-your-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL Database Configuration
# Leave DB_NAME empty if you want to default to SQLite for quick testing
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# React Frontend Configuration
VITE_API_URL=http://localhost:8000/api/

# Supabase Storage S3 Configuration
SUPABASE_REF=your-supabase-project-ref
AWS_ACCESS_KEY_ID=your-s3-access-key-id
AWS_SECRET_ACCESS_KEY=your-s3-secret-access-key
AWS_STORAGE_BUCKET_NAME=your-public-bucket-name
AWS_S3_ENDPOINT_URL=https://your-supabase-project-ref.supabase.co/storage/v1/s3

